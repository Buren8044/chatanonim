{
  "rules": {
    "musteriler": {
      "$musteriId": {
        ".read":  "auth == null",
        ".write": "auth == null",
        "config": {
          "push_token": { ".write": "auth == null" }
        }
      }
    },
    "sohbetler": {
      "$chatId": {
        ".read":  "auth == null",
        "mesajlar": {
          "$msgId": {
            ".write": "auth == null",
            ".validate": "newData.hasChildren(['text', 'ts']) || newData.hasChildren(['url', 'ts'])"
          }
        },
        "meta": {
          ".write": "auth == null"
        },
        "isTyping": {
          ".write": "auth == null"
        },
        "typing": {
          ".write": "auth == null"
        }
      }
    },
    "istekler": {
      "$musteriId": {
        ".read":  "auth == null",
        ".write": "auth == null"
      }
    },
    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
